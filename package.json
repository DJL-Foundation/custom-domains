{
  "name": "custom-domains",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "postinstall": "concurrently -k -p \"[{name}]\" -n \"postinstall:*\" \"bun:postinstall:*\"",
    "postinstall:scripts": "bun /scripts/postinstall.ts",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check",
    "postversion": "bun postinstall:scripts"
  },
  "dependencies": {
    "@effect/opentelemetry": "^0.61.0",
    "@effect/platform": "^0.94.5",
    "@effect/platform-bun": "^0.87.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "bun": "^1.3.10",
    "concurrently": "^9.2.1",
    "effect": "^3.19.19",
    "hono": "^4.12.5",
    "zod": "^4.3.6",
    "zod_utilz": "^0.8.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "wrangler": "^4.71.0"
  }
}
